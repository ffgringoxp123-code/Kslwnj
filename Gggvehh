    pcall(function()
        local ball = nil
        if Balls then
            for _, v in ipairs(Balls:GetChildren()) do
                if v:GetAttribute("realBall") then ball = v; break end
            end
        end
        if not ball then return end
        
        local char = Player.Character
        if not char or not char.PrimaryPart then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        if S.SI then
            local zoomies = ball:FindFirstChild("zoomies")
            if not zoomies then return end
            local vel = zoomies.VectorVelocity
            local dir = vel.Unit
            local ballPos = ball.Position
            
            local orbitPos = ballPos + dir * orbitR + Vector3.new(0, orbitH, 0)
            hrp.CFrame = CFrame.new(orbitPos, ballPos)
        end
        
        if S.IM then
            local zoomies = ball:FindFirstChild("zoomies")
            if not zoomies then return end
            local vel = zoomies.VectorVelocity
            local dir = vel.Unit
            local ballPos = ball.Position
            local perp = dir:Cross(Vector3.new(0, 1, 0))
            if perp.Magnitude < 0.01 then
                perp = dir:Cross(Vector3.new(1, 0, 0))
            end
            perp = perp.Unit
            
            local angle = (tick() * 2) % (math.pi * 2)
            local offset = perp * math.cos(angle) * imOrbitR + Vector3.new(0, math.sin(angle) * 5, 0)
            local orbitPos = ballPos + offset
            
            hrp.CFrame = CFrame.new(orbitPos, ballPos)
        end
    end)
end)

-- ============================================================
-- AUTO DODGE
-- ============================================================
RunService.Heartbeat:Connect(function()
    if not S.AD then return end
    pcall(function()
        local ball = nil
        if Balls then
            for _, v in ipairs(Balls:GetChildren()) do
                if v:GetAttribute("realBall") then ball = v; break end
            end
        end
        if not ball then return end
        
        local char = Player.Character
        if not char or not char.PrimaryPart then return end
        
        local zoomies = ball:FindFirstChild("zoomies")
        if not zoomies then return end
        
        local vel = zoomies.VectorVelocity
        local speed = vel.Magnitude
        if speed < 10 then return end
        
        local dirToBall = (ball.Position - char.PrimaryPart.Position).Unit
        local dot = dirToBall:Dot(vel.Unit)
        
        if dot > 0.7 then
            local distance = (char.PrimaryPart.Position - ball.Position).Magnitude
            local ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
            local threshold = math.clamp(ping / 10, 5, 20) + math.min(speed / 20, 30)
            
            if distance < threshold then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dodgeDir = vel:Cross(Vector3.new(0, 1, 0)).Unit
                    if dodgeDir.Magnitude < 0.1 then
                        dodgeDir = Vector3.new(1, 0, 0)
                    end
                    hrp.CFrame = hrp.CFrame + dodgeDir * 15 + Vector3.new(0, 3, 0)
                end
            end
        end
    end)
end)

