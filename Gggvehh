local apConn = nil

RunService.Heartbeat:Connect(function()
    if S.AP and not apConn then
        apConn = RunService.RenderStepped:Connect(function()
            if not S.AP or not Player.Character or not Player.Character.PrimaryPart then return end
            
            local balls = GetBalls()
            local trainingBall = nil
            
            if TrainingBalls then
                for _, v in ipairs(TrainingBalls:GetChildren()) do
                    if v:GetAttribute("realBall") then trainingBall = v; break end
                end
            end
            
            for _, ball in ipairs(balls) do
                if not ball then continue end
                local zoomies = ball:FindFirstChild("zoomies")
                if not zoomies then continue end
                
                if Sys.__parried then continue end
                
                local ballTarget = ball:GetAttribute("target")
                local velocity = zoomies.VectorVelocity
                local distance = (Player.Character.PrimaryPart.Position - ball.Position).Magnitude
                local ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
                local pingThreshold = math.clamp(ping / 10, 5, 17)
                local speed = velocity.Magnitude
                
                if speed <= 0 then continue end
                
                local cappedSpeedDiff = math.min(math.max(speed - 9.5, 0), 650)
                local speedDivisor = (2.5 + cappedSpeedDiff * 0.002) * Speed_Divisor_Multiplier
                local parryAccuracy = pingThreshold + math.max(speed / speedDivisor, 9.5)
                parryAccuracy = parryAccuracy + math.clamp(ping / 1000 * speed, 0, 30)
                
                if speed > 1500 then
                    local m = 1 + (speed - 1500) / 1000
                    parryAccuracy = parryAccuracy * math.clamp(m, 1.5, 3.5)
                end
                
                local dirToPlayer = (Player.Character.PrimaryPart.Position - ball.Position).Unit
                local dotToPlayer = dirToPlayer:Dot(velocity.Unit)
                
                if ballTarget ~= Player.Name and dotToPlayer < 0.1 then continue end
                
                if ball:FindFirstChild("AeroDynamicSlashVFX") then
                    pcall(function() ball.AeroDynamicSlashVFX:Destroy() end)
                end
                
                if Runtime and Runtime:FindFirstChild("Tornado") then
                    local tornadoTime = (Runtime.Tornado:GetAttribute("TornadoTime") or 1) + 0.314159
                    if (tick() - Sys.__tornado_time) < tornadoTime then continue end
                end
                
                if IsCurvedMixed() and ballTarget == Player.Name then continue end
                if ball:FindFirstChild("ComboCounter") then continue end
                if Player.Character.PrimaryPart:FindFirstChild("SingularityCape") then continue end
                if S.ID and Sys.__infinity_active then continue end
                if IsParryOnCooldown() then continue end
                
                local closestPlayer = GetClosest()
                if closestPlayer and not Sys.__antidot_parried then
                    local playerDist = (Player.Character.PrimaryPart.Position - closestPlayer.PrimaryPart.Position).Magnitude
                    if playerDist <= 30 and dotToPlayer > 0.75 then
                        if ballTarget == Player.Name and distance <= 30 then
                            DoFire()
                            Sys.__parried = true
                            Sys.__antidot_parried = true
                        end
                    end
                end
                
                if S.TB and closestPlayer and closestPlayer.Name == ballTarget then
                    local distToClosest = (Player.Character.PrimaryPart.Position - closestPlayer.PrimaryPart.Position).Magnitude
                    if distToClosest <= 35 and ballTarget == Player.Name and distance <= parryAccuracy then
                        DoFire()
                        Sys.__parried = true
                    end
                else
                    if ballTarget == Player.Name and distance <= parryAccuracy then
                        if Parries > 7 then continue end
                        Parries = Parries + 1
                        task.delay(0.5, function()
                            if Parries > 0 then Parries = Parries - 1 end
                        end)
                        DoFire()
                        Sys.__parried = true
                    end
                end
                
                if Sys.__parried then
                    local t0 = tick()
                    repeat RunService.RenderStepped:Wait() until (tick() - t0) >= 1 or not Sys.__parried
                    Sys.__parried = false
                    Sys.__antidot_parried = false
                end
            end
            
            -- Training ball handling
            if trainingBall and S.LAP then
                local tz = trainingBall:FindFirstChild("zoomies")
                if tz then
                    if not Sys.__training_parried then
                        local bt = trainingBall:GetAttribute("target")
                        local spd = tz.VectorVelocity.Magnitude
                        local dist = Player:DistanceFromCharacter(trainingBall.Position)
                        local ping2 = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
                        local pingT = math.clamp(ping2 / 10, 5, 17)
                        local csd = math.min(math.max(spd - 9.5, 0), 650)
                        local spdDiv = (2.5 + csd * 0.002) * Speed_Divisor_Multiplier
                        local pa = pingT + math.max(spd / spdDiv, 9.5) + math.clamp(ping2 / 1000 * spd, 0, 30)
                        
                        if spd > 1500 then
                            local m2 = 1 + (spd - 1500) / 1000
                            pa = pa * math.clamp(m2, 1.5, 3.5)
                        end
                        
                        if bt == Player.Name and dist <= pa then
                            DoFire()
                            Sys.__training_parried = true
                            local t0 = tick()
                            repeat RunService.RenderStepped:Wait() until (tick() - t0) >= 1 or not Sys.__training_parried
                            Sys.__training_parried = false
                        end
                    end
                end
            end
        end)
    elseif not S.AP and apConn then
        apConn:Disconnect()
        apConn = nil
    end
end)

