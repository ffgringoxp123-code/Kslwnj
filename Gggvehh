local function IsParryOnCooldown()
    if not S.CD then return false end
    local result = false
    pcall(function()
        local hotbar = Player.PlayerGui:FindFirstChild("Hotbar")
        if not hotbar then return end
        local block = hotbar:FindFirstChild("Block")
        if not block then return end
        local parryGrad = block:FindFirstChildOfClass("UIGradient")
        if parryGrad and parryGrad.Offset.Y < 0.4 then
            result = true
            return
        end
    end)
    return result
end

