-- TRIGGERBOT
-- ============================================================
RunService.Heartbeat:Connect(function()
    if not S.TB then return end
    pcall(function()
        local char = Player.Character
        if not char or not char.PrimaryPart then return end
        
        local closest = GetClosestToCursor()
        if not closest or not closest.PrimaryPart then return end
        
        local distance = (char.PrimaryPart.Position - closest.PrimaryPart.Position).Magnitude
        if distance > 35 then return end
        
        local ball = nil
        if Balls then
            for _, v in ipairs(Balls:GetChildren()) do
                if v:GetAttribute("realBall") then ball = v; break end
            end
        end
        if not ball then return end
        
        local ballTarget = ball:GetAttribute("target")
        if ballTarget == closest.Name or ballTarget == Player.Name then
            local zoomies = ball:FindFirstChild("zoomies")
            if not zoomies then return end
            
            local speed = zoomies.VectorVelocity.Magnitude
            local ballDist = (char.PrimaryPart.Position - ball.Position).Magnitude
            local ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
            local threshold = math.clamp(ping / 10, 5, 17) + math.max(speed / 6, 9.5)
            
            if ballDist <= threshold then
                DoFire()
            end
        end
    end)
end)

