task.spawn(function()
    pcall(function()
        local mt2 = getrawmetatable(game)
        local old2 = mt2.__index
        setreadonly(mt2, false)
        mt2.__index = newcclosure(function(self, key)
            if key == "FireServer" and self:IsA("RemoteEvent") then
                return newcclosure(function(_, ...)
                    local a = { ... }
                    if #a == 7 and type(a[2]) == "string" and type(a[3]) == "number"
                        and typeof(a[4]) == "CFrame" and type(a[5]) == "table"
                        and type(a[6]) == "table" and type(a[7]) == "boolean"
                        or self.Name:find("Parry") then
                        revertedRemotes[self] = a
                        if not hasData then
                            hasData = true
                            print("[Gesti Hub] Remote captured!")
                        end
                    end
                    return old2(self, key)(self, ...)
                end)
            end
            return old2(self, key)
        end)
        setreadonly(mt2, true)
    end)
end)

-- Fallback filtergc
task.spawn(function()
    task.wait(1)
    pcall(function()
        local t2
        for _, v in filtergc("table", {}) do
            local valid = true
            for i = 0, 1 do
                local r = rawget(v, i)
                if not (typeof(r) == "Instance" and r:IsA("RemoteEvent")) then
                    valid = false
                    break
                end
            end
            if valid then t2 = v; break end
        end
        if not t2 then return end
        
        local uuids = {}
        for _, v in pairs(t2) do
            if type(v) == "string" and v:match("%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x") then
                table.insert(uuids, v)
            end
        end
        local info = rawget(t2, 3)
        if not info then return end
        local selector = rawget(info, 3)
        local uuid = uuids[selector]
        local hash = rawget(info, 2)
        if not uuid or not hash then return end
        
        local remoteyield = Instance.new("BindableEvent")
        local waxfs = (game:FindFirstChildWhichIsA("RemoteEvent", true) or Instance.new("RemoteEvent")).FireServer
        local fs
        fs = hookfunction(waxfs, function(self, ...)
            if not checkcaller() and self:IsA("RemoteEvent") and select(1, ...) == uuid and select(2, ...) == hash then
                hookfunction(waxfs, fs)
                remoteyield:Fire(self)
            end
            return fs(self, ...)
        end)
        
        local rf = remoteyield.Event:Wait()
        hasData = true
        revertedRemotes[rf] = { uuid, hash, 0.5, workspace.CurrentCamera.CFrame, {}, { workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y / 2 }, false }
        print("[Gesti Hub] Remote captured via filtergc!")
    end)
end)

