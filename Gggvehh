            if Balls then
                for _, v in ipairs(Balls:GetChildren()) do
                    if v:GetAttribute("realBall") then ball = v; break end
                end
            end
            if not ball then return end
            
            local zoomies = ball:FindFirstChild("zoomies")
            if not zoomies then return end
            
            if now - (Sys.__target_check_time or 0) > 0.1 then
                Sys.__target_check_time = now
                local ce = GetClosest()
                if ce then
                    if Sys.__spam_target then
                        if not Sys.__spam_target.Parent or not Sys.__spam_target:FindFirstChild("Humanoid")
                            or Sys.__spam_target.Humanoid.Health <= 0 then
                            Sys.__spam_target = nil
                        end
                    end
                    if not Sys.__spam_target or (now - (Sys.__spam_target_time or 0) > 1) then
                        Sys.__spam_target = ce
                        Sys.__spam_target_time = now
                    end
                end
            end
            
            local ballTarget = ball:GetAttribute("target")
            if not ballTarget then return end
            
            local vel = ball.AssemblyLinearVelocity or Vector3.zero
            local speed = vel.Magnitude
            if speed < 5 then return end
            
            local hr = char.PrimaryPart
            local dir = (hr.Position - ball.Position).Unit
            local dot = dir:Dot(vel.Unit)
            local ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
            local pingThreshold = math.clamp(ping / 10, 1, 16)
            local maxSpamDist = pingThreshold + math.min(speed / 6, 95)
            local maxSpeed = 5 - math.min(speed / 5, 5)
            local maxDot = math.clamp(dot, -1, 0) * maxSpeed
            local spamAcc = maxSpamDist - maxDot
            
            local entity = Closest_Entity
            if not entity or not entity.PrimaryPart then return end
            
            local entityDist = (hr.Position - entity.PrimaryPart.Position).Magnitude
            local ballDist = Player:DistanceFromCharacter(ball.Position)
            local targetDist = Player:DistanceFromCharacter(entity.PrimaryPart.Position)
            
            if entityDist > maxSpamDist then return end
            if ballDist > spamAcc then return end
            if targetDist > maxSpamDist then return end
            if ballTarget == Player.Name and targetDist > 30 and ballDist > 30 then return end
            if char:GetAttribute("Pulsed") then return end
            
            local spamTarget = Sys.__spam_target
            if not spamTarget then return end
            if ballTarget ~= spamTarget.Name and ballTarget ~= Player.Name then return end
            
            if targetDist <= spamAcc and ballDist <= spamAcc then
                if Parries > ParryThreshold then
                    DoFire()
                end
            end
        end)
    elseif not S.AS and asConn then
        asConn:Disconnect()
        asConn = nil
    end
end)

