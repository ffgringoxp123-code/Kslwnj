-- FIRE PARRY
-- ============================================================
local DoFire = function()
    if not Player.Character then return end
    local cam = workspace.CurrentCamera
    local ok, mouse = pcall(function() return UserInputService:GetMouseLocation() end)
    if not ok then return end
    local vec2 = {
        (isMobile and not false) and cam.ViewportSize.X / 2 or mouse.X,
        (isMobile and not false) and cam.ViewportSize.Y / 2 or mouse.Y
    }
    local eventData = {}
    if Alive then
        for _, entity in pairs(Alive:GetChildren()) do
            if entity.PrimaryPart then
                pcall(function()
                    local sp = cam:WorldToScreenPoint(entity.PrimaryPart.Position)
                    eventData[entity.Name] = sp
                end)
            end
        end
    end
    local cf = GetCFrame()
    if not Sys.__first_parry_done then
        pcall(function()
            for _, conn in pairs(getconnections(Player.PlayerGui.Hotbar.Block.Activated)) do
                conn:Fire()
            end
        end)
        Sys.__first_parry_done = true
        serverFireCounter = serverFireCounter + 1
        return
    end
    for rem, args in pairs(revertedRemotes) do
        local modified = { args[1], args[2], args[3], cf, eventData, vec2, args[7] }
        pcall(function()
            if rem:IsA("RemoteEvent") then
                rem:FireServer(table.unpack(modified))
            elseif rem:IsA("RemoteFunction") then
                rem:InvokeServer(table.unpack(modified))
            end
        end)
    end
    serverFireCounter = serverFireCounter + 1
    if Parries < 10000 then
        Parries = Parries + 1
        task.delay(0.5, function()
            if Parries > 0 then Parries = Parries - 1 end
        end)
    end
end

